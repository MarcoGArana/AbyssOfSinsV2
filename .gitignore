# This .gitignore file is configured for Unity projects.
# It excludes auto-generated directories, build artifacts, and IDE/OS-specific files.

# Unity auto-generated files and folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
.utmp/
/[Uu]i[Ee]lements[Ss]chema/

# Memory captures and recordings can get extremely large
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Blender auto-generated backup files
*.blend1
*.blend1.meta

# Autogenerated Jetbrains Rider plugin and settings
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user
.idea/

# Visual Studio cache directory and files
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.private

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds and Packages
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db